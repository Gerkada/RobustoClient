<DefaultWindow xmlns="https://spacestation14.io"
               Title="AutoChem Interface"
               MinSize="400 500"
               SetSize="400 500">
    <BoxContainer Orientation="Vertical" HorizontalExpand="True" VerticalExpand="True" SeparationOverride="8" Margin="8">
        <BoxContainer Orientation="Horizontal" HorizontalExpand="True" SeparationOverride="4">
            <LineEdit Name="SearchBar" PlaceHolder="Search chemical..." HorizontalExpand="True" />
            <LineEdit Name="AmountInput" PlaceHolder="Amount (e.g. 30)" Text="30" MinWidth="100" />
            <Button Name="StartStopButton" Text="Start" StyleClasses="ButtonColorGreen" />
        </BoxContainer>
        
        <Label Name="StatusLabel" Text="Select a chemical" HorizontalAlignment="Center" FontColorOverride="Yellow" />
        
        <ScrollContainer VerticalExpand="True" HorizontalExpand="True">
            <BoxContainer Name="ChemListContainer" Orientation="Vertical" HorizontalExpand="True" SeparationOverride="4" />
        </ScrollContainer>
    </BoxContainer>
</DefaultWindow>
